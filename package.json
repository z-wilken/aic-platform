{
  "name": "aic-platform-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/web",
    "apps/platform",
    "apps/engine",
    "apps/governance-agent",
    "packages/*"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web -- --port 3000",
    "dev:platform": "turbo dev --filter=platform -- --port 3001",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' turbo build --filter=web --concurrency=1",
    "test": "turbo test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:engine": "cd apps/engine && pytest tests/ -v --tb=short",
    "test:e2e": "npx playwright test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "npm run db:migrate --workspace @aic/db",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "1.51.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.16.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.3.0",
    "concurrently": "^8.2.0",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^1.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "vitest related --run"
    ]
  },
  "overrides": {
    "playwright": "1.51.1"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "next": "15.5.15",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.18.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
